#Section: Simulated Keystrokes dialog - help text
# NOTE: For the following texts, \r\n is a NEW LINE and \t is a TAB. Be sure to check the layout on the simkeys
# dialog when making translations to ensure your text is visible and fits nicely.
"Type the key sequence into the box above.\r\nYou can simulate the following extended keys using the specified tags..." => "请在上方的方框内输入按键序列。\r\n您可以使用特定的标记来模拟下列的扩展按键: "
"Modifier tags:\r\n  {CTRL} {RCTRL} {ALT} {RALT} {SHIFT} {RSHIFT} {LWIN} {RWIN} {APPS}\r\n  NOTE:\tmodifier tags can be combined like {CTRL}{ALT} but apply to the NEXT KEY ONLY.\r\n\tFor example, to send CTRL+a+CTRL+s you should type '{CTRL}A{CTRL}S'." => "辅助按键标记: \r\n  {CTRL} {RCTRL} {ALT} {RALT} {SHIFT} {RSHIFT} {LWIN} {RWIN} {APPS}\r\n  注意: \t辅助按键标记可以如 {CTRL}{ALT} 一样组合使用，但“仅应用到下一个”普通按键。\r\n\t举个例子，若想发送 CTRL+a+CTRL+s，您应该输入“{CTRL}A{CTRL}S”。"

# -- Updated in 2.14 beta 2 --
"Extended key tags:\r\n  {DEL} {INS} {PGUP} {PGDN} {HOME} {END} {RETURN} {ESCAPE} {BACKSPACE}\r\n  {TAB} {PRTSCN} {PAUSE} {SPACE} {CAPSLOCK} {NUMLOCK} {SCROLLLOCK} {BREAK} {CTRLBREAK}" => "扩展键标记: \r\n  {DEL} {INS} {PGUP} {PGDN} {HOME} {END} {RETURN} {ESCAPE} {BACKSPACE}\r\n  {TAB} {PRTSCN} {PAUSE} {SPACE} {CAPSLOCK} {NUMLOCK} {SCROLLLOCK} {BREAK} {CTRLBREAK}"

# -- Updated in 2.9 beta 6 --
"For example:\r\n  To close a window: {ALT}{F4}\r\n  To select all items: {CTRL}A\r\n  To type bold 'my text' in Microsoft Word: {CTRL}bmy text{CTRL}b\r\n  To send an 'r' key with a 50ms delay between the down and up, {HOLDMS:50}r\r\n  To turn OFF numlock, {NUMLOCKOFF}" => "示例: \r\n    关闭一个窗口: {ALT}{F4}\r\n    选中所有项目: {CTRL}A\r\n    在 Microsoft Word 中输入加粗的“my text”文本: {CTRL}bmy text{CTRL}b\r\n    在按键按下与松开期间以 50 毫秒延时反复键入“r”键: {HOLDMS:50}r\r\n    关闭数字键锁定: {NUMLOCKOFF}"

# -- Added in 2.9 beta 6 --
"Special tags for send methods 1,2,4,5,6,7 & 9:\r\n\t\t\t{PRESS} Press down the following key\r\n\t\t\t{RELEASE} Release (let go of) the following key\r\n\t\t\tNOTE: You must {RELEASE} any key you {PRESS} in the same sequence!" => "发送方法 1,2,4,5,6,7,9 的特殊标记: \r\n\t\t\t{PRESS} 按下下列键: \r\n\t\t\t{RELEASE}松开下列键\r\n\t\t\t注意: 您必须在同一序列中松开 ({RELEASE}) 您按下 ({PRESS}) 的所有键！"
"To press a b and c, wait 100ms and release them: {PRESS}abc{WAITMS100}{RELEASE}cba" => "要按下 a b c 并在等待 100 毫秒后松开，只需: {PRESS}abc{WAITMS100}{RELEASE}cba"
# --

# -- Updated in 2.4 Beta 10 and removed in 2.9 Beta 6 --
"NOTE: To avoid lag when using the {WAIT}, {WAITMS}, {HOLD} or {HOLDMS} tags, try using the threaded\r\nsend methods in the dropdown above." => "注意: 为避免在使用 {WAIT}、{WAITMS}、{HOLD} 以及 {HOLDMS} 标记时发生延迟卡顿，请尝试在上方的下拉列表中\r\n选择使用独立线程的发送方式。"

# -- Updated in 2.4 Beta 15 --
"Special function tags:\t{WAIT:n} inserts a delay of <n> seconds.\r\n\t\t\t{WAITMS:n} inserts a delay of <n> milliseconds.\r\n\t\t\t{HOLD:n} holds the next key down for <n> seconds.\r\n\t\t\t{HOLDMS:n} holds the next key down for <n> milliseconds.\r\n\t\t\t{VKC:n} Sends the specified virtual key code.\r\n\t\t\t{EXT:n} Sends the specified extended virtual key code.\r\n\t\t\t{CLEAR} Clears any modifier tags {CTRL},{ALT} etc." => "特殊功能标记: \t\t{WAIT:n}  插入一个 <n> 秒的延迟。\r\n\t\t\t{WAITMS:n}  插入一个 <n> 毫秒的延迟。\r\n\t\t\t{HOLD:n}  按住下一个按键不放维持 <n> 秒。\r\n\t\t\t{HOLDMS:n} 按住下一个按键不放维持 <n> 毫秒。\r\n\t\t\t{VKC:n}  发送指定的虚拟键盘编码。\r\n\t\t\t{EXT:n}  发送指定的扩展虚拟键盘编码\r\n\t\t\t{CLEAR}  清除所有辅助按键标记包括 {CTRL}、{ALT} 等。"

# -- Updated in 2.20 Beta 4 --
"Special function tags:\t{WAIT:n} inserts a delay of <n> seconds." => "特殊功能标记: \t\t{WAIT:n}  插入一个 <n> 秒的延迟。"
"\t\t\t{WAITMS:n} inserts a delay of <n> milliseconds." => "\t\t\t{WAITMS:n}  插入一个 <n> 毫秒的延迟。"
"\t\t\t{WAITMS:x-y} inserts a random delay of between <x> and <y> milliseconds." => "\t\t\t{WAITMS:x-y} 插入一个长度介于 <x> 和 <y> 毫秒之间的随机延迟。"
"\t\t\t{HOLD:n} holds the next key down for <n> seconds." => "\t\t\t{HOLD:n}  按住下一个按键不放维持 <n> 秒。"
"\t\t\t{HOLDMS:n} holds the next key down for <n> milliseconds." => "\t\t\t{HOLDMS:n} 按住下一个按键不放维持 <n> 毫秒。"
"\t\t\t{VKC:n} Sends the specified virtual key code." => "\t\t\t{VKC:n}  发送指定的虚拟键盘编码。"
"\t\t\t{EXT:n} Sends the specified extended virtual key code." => "\t\t\t{EXT:n}  发送指定的扩展虚拟键盘编码。"
"\t\t\t{CLEAR} Clears any modifier tags {CTRL},{ALT} etc." => "\t\t\t{CLEAR}  清除所有辅助按键标记包括 {CTRL}、{ALT} 等。"

#Added in 2.17 Beta 16
"\t\t\t{SC:n} Sends the specified keyboard scan code." => "\t\t\t{SC:n} 发送指定的键盘扫描码。"
"\t\t\t{SCE:n} Sends the specified extended keyboard scan code." => "\t\t\t{SCE:n} 发送指定的扩展键盘扫描码。"
"\t\t\t{CB:<text>} Copies the specified <text> to the clipboard." => "\t\t\t{CB:<text>} 复制指定文本至剪贴板。"
#

# -- Updated in 2.14 Beta 2 --
"Direction key tags:\t\t{UP} {DOWN} {LEFT} {RIGHT}\r\nFunction key tags:\t\t{F1, F2, F3 ... F24}\r\nVolume key tags:\t\t{VOL+}, {VOL-}, {MUTE}\r\nBrightness control tags:\t\t{BRIGHTNESS+}, {BRIGHTNESS-}\r\nMouse button tags:\t\t{LMB}, {RMB}, {MMB}, {MB4/XMB1}, {MB5/XMB2}\r\nMouse wheel tags:\t\t{MWUP}, {MWDN}, {TILTL}, {TILTR}\r\nNumeric keypad tags:\t{NUM0-NUM9} {NUM+} {NUM-} {NUM.} {NUM/} {NUM*} {NUMENTER}\r\nWeb/Browser keys:\t\t{BACK}, {FORWARD}, {STOP}, {REFRESH}, {WEBHOME},\r\n\t\t\t{SEARCH}, {FAVORITES}\r\nToggle keys:\t\t{NUMLOCKON}, {NUMLOCKOFF}, {CAPSLOCKON}\r\n\t\t\t{CAPSLOCKOFF}, {SCROLLLOCKON}, {SCROLLLOCKOFF}" => "方向键标记: \t\t{UP} {DOWN} {LEFT} {RIGHT}\r\n功能键标记: \t\t{F1、F2、F3 ... F24}\r\n音量键标记: \t\t{VOL+}、{VOL-}、{MUTE}\r\n\r\n亮度控制标记: \t\t{BRIGHTNESS+}、{BRIGHTNESS-}\r\n鼠标按键标记: \t\t{LMB}、{RMB}、{MMB}、{MB4/XMB1}、{MB5/XMB2}\r\n鼠标滚轮标记: \t\t{MWUP}、{MWDN}、{TILTL}、{TILTR}\r\n数字小键盘标记: \t{NUM0-NUM9} {NUM+} {NUM-} {NUM.} {NUM/} {NUM*} {NUMENTER}\r\n网页/浏览器按键: \t\t{BACK}、{FORWARD}、{STOP}、{REFRESH}、{WEBHOME}、\r\n\t\t\t{SEARCH}、{FAVORITES}\r\n开关切换按键: \t\t{NUMLOCKON}、{NUMLOCKOFF}、{CAPSLOCKON}\r\n\t\t\t{CAPSLOCKOFF}、{SCROLLLOCKON}、{SCROLLLOCKOFF}"

# -- Removed in 2.18 Beta 12 --
"Direction key tags:\t\t{UP} {DOWN} {LEFT} {RIGHT}\r\nFunction key tags:\t\t{F1, F2, F3 ... F24}\r\nVolume key tags:\t\t{VOL+}, {VOL-}, {MUTE}\r\nBrightness control tags:\t{BRIGHTNESS+}, {BRIGHTNESS-}\r\nMouse button tags:\t\t{LMB}, {RMB}, {MMB}, {MB4/XMB1}, {MB5/XMB2}\r\nMouse wheel tags:\t\t{MWUP}, {MWDN}, {TILTL}, {TILTR}\r\nNumeric keypad tags:\t{NUM0-NUM9} {NUM+} {NUM-} {NUM.} {NUM/} {NUM*} {NUMENTER}\r\nWeb/Browser keys:\t\t{BACK}, {FORWARD}, {STOP}, {REFRESH}, {WEBHOME},\r\n\t\t\t{SEARCH}, {FAVORITES}\r\nToggle keys:\t\t{NUMLOCKON}, {NUMLOCKOFF}, {CAPSLOCKON}\r\n\t\t\t{CAPSLOCKOFF}, {SCROLLLOCKON}, {SCROLLLOCKOFF}" => "方向键标记: \t\t{UP} {DOWN} {LEFT} {RIGHT}\r\n功能键标记: \t\t{F1、F2、F3 ... F24}\r\n音量键标记: \t\t{VOL+}、{VOL-}、{MUTE}\r\n\r\n亮度控制标记: \t{BRIGHTNESS+}、{BRIGHTNESS-}\r\n鼠标按键标记: \t\t{LMB}、{RMB}、{MMB}、{MB4/XMB1}、{MB5/XMB2}\r\n鼠标滚轮标记: \t\t{MWUP}、{MWDN}、{TILTL}、{TILTR}\r\n数字小键盘标记: \t{NUM0-NUM9} {NUM+} {NUM-} {NUM.} {NUM/} {NUM*} {NUMENTER}\r\n网页/浏览器按键: \t\t{BACK}、{FORWARD}、{STOP}、{REFRESH}、{WEBHOME}、\r\n\t\t\t{SEARCH}、{FAVORITES}\r\n开关切换按键: \t\t{NUMLOCKON}、{NUMLOCKOFF}、{CAPSLOCKON}\r\n\t\t\t{CAPSLOCKOFF}、{SCROLLLOCKON}、{SCROLLLOCKOFF}"

# -- Changed (split up) in 2.18 Beta 12
"Direction key tags:\t\t{UP} {DOWN} {LEFT} {RIGHT}" => "方向键标记:\t\t{UP} {DOWN} {LEFT} {RIGHT}"
"Function key tags:\t\t{F1, F2, F3 ... F24}" => "功能键标记:\t\t{F1, F2, F3 ... F24}"
"Volume key tags:\t\t{VOL+}, {VOL-}, {MUTE}" => "音量键标记:\t\t{VOL+}, {VOL-}, {MUTE}"
"Brightness control tags:\t{BRIGHTNESS+}, {BRIGHTNESS-}" => "亮度控制键标记:\t{BRIGHTNESS+}, {BRIGHTNESS-}"
"Mouse button tags:\t\t{LMB}, {RMB}, {MMB}, {MB4/XMB1}, {MB5/XMB2}" => "鼠标按键标记:\t\t{LMB}, {RMB}, {MMB}, {MB4/XMB1}, {MB5/XMB2}"
"Mouse button up/down tags:\tAdd a D (for down/pressed)" => "鼠标按键按下/释放标记:\t添加字母 D 或 U 在上述鼠标按键标记之后"
"\t\t\tor a U (for up/released) to the mouse button tags (above)" => "\t\t\t以表示鼠标按键的按下或释放，"
"\t\t\te.g. {LMBD}, {LMBU}, {RMBD}, {RMBU}, {MB4D}, {MB5U} etc." => "\t\t\t例如 {LMBD}, {LMBU}, {RMBD}, {RMBU}, {MB4D}, {MB5U} etc." #Updated in 2.18 Beta 13
"Mouse wheel tags:\t\t{MWUP}, {MWDN}, {TILTL}, {TILTR}" => "鼠标滚轮标记:\t\t{MWUP}, {MWDN}, {TILTL}, {TILTR}"
"Numeric keypad tags:\t{NUM0-NUM9} {NUM+} {NUM-} {NUM.} {NUM/} {NUM*} {NUMENTER}" => "数字键盘标记:\t\t{NUM0-NUM9} {NUM+} {NUM-} {NUM.} {NUM/} {NUM*} {NUMENTER}" #Fixed in 2.18 Beta 13
"Web/Browser keys:\t\t{BACK}, {FORWARD}, {STOP}, {REFRESH}, {WEBHOME}, {SEARCH}, {FAVORITES}" => "浏览器按键标记:\t\t{BACK}, {FORWARD}, {STOP}, {REFRESH}, {WEBHOME}, {SEARCH}, {FAVORITES}"
"Toggle keys:\t\t{NUMLOCKON}, {NUMLOCKOFF}, {CAPSLOCKON}, {CAPSLOCKOFF},\r\n\t\t\t{SCROLLLOCKON}, {SCROLLLOCKOFF}" => "切换锁定键标记:\t\t{NUMLOCKON}, {NUMLOCKOFF}, {CAPSLOCKON}, {CAPSLOCKOFF},\r\n\t\t\t{SCROLLLOCKON}, {SCROLLLOCKOFF}"
# --

# -- Added in 2.11 Beta 16 --
"Movement tags\t\t{MXSET:n} {MYSET:n} {MXADD:n} {MYADD:n}\r\n\t\t\tSET sets the mouse cursor's X or Y position to <n>\r\n\t\t\tADD moves the mouse cursor's X or Y position by <n> pixels" => "移动标记\t\t{MXSET:n} {MYSET:n} {MXADD:n} {MYADD:n}\r\n\t\t\t设定指针的 X 和 Y 坐标到 <n>\r\n\t\t\t增量移动指针的 X 或 Y 坐标，<n> 像素"

# -- Changed in 2.15 beta 7, 8 & 9 --
"Movement tags:\t\t{MADD:x,y} Move cursor X & Y position by <x,y> pixels" => "移动标记:\t\t{MADD:x,y} 移动指针的 X 或 Y 坐标 <x,y> 像素"
"\t\t\t{MSET:x,y} Set cursor position to <x,y> (relative to primary monitor)" => "\t\t\t{MSET:x,y} 设置指针坐标至 <x,y> (相对于主显示器)"
"\t\t\t{PSET:x,y} Set cursor position to <x,y> (relative to profile window)" => "\t\t\t{PSET:x,y} 设置指针坐标至 <x,y> (相对于配置文件指定窗口)"
"\t\t\t{ASET:x,y} Set cursor position to <x,y> (relative to active window)" => "\t\t\t{ASET:x,y} 设置指针坐标至 <x,y> (相对于活动窗口)"
"\t\t\t{MSAVE:n} Save the current cursor position to memory <n> (1-10)" => "\t\t\t{MSAVE:n} 保存当前指针坐标至位置记忆 <n> (1-10)" #Updated in 2.16 Beta 17
"\t\t\t{MREST:n} Restore the saved cursor position from memory <n> (1-10)" => "\t\t\t{MREST:n} 从位置记忆 <n> (1-10) 恢复指针坐标" #Updated in 2.16 Beta 17

# -- Deprecated in 2.15 Beta 9 - they still work but are not displayed
"Movement tags:\t\t{MXADD:n} Move cursor X position (horizontally) by <n> pixels" => "移动标记:\t\t{MXADD:n} 移动指针的 X 坐标 (横向) <n> 个像素"
"\t\t\t{MYADD:n} Move cursor Y position (vertically) by <n> pixels" => "\t\t\t{MYADD:n} 移动指针的 Y 坐标 (纵向) <n> 个像素"
"\t\t\t{MXSET:n} Set cursor X position to <n> (relative to primary monitor)" => "\t\t\t{MXSET:n} 设置指针 X 坐标至 <n> (相对于主显示器)"
"\t\t\t{MYSET:n} Set cursor Y position to <n> (relative to primary monitor)" => "\t\t\t{MYSET:n} 设置指针 Y 坐标至 <n> (相对于主显示器)"
"\t\t\t{PXSET:n} Set cursor X position to <n> (relative to profile window)" => "\t\t\t{PXSET:n} 设置指针 X 坐标至 <n> (相对于配置文件指定窗口)"
"\t\t\t{PYSET:n} Set cursor Y position to <n> (relative to profile window)" => "\t\t\t{PYSET:n} 设置指针 Y 坐标至 <n> (相对于配置文件指定窗口)"
"\t\t\t{AXSET:n} Set cursor X position to <n> (relative to active window)" => "\t\t\t{AXSET:n} 设置指针 X 坐标至 <n> (相对于活动窗口)"
"\t\t\t{AYSET:n} Set cursor Y position to <n> (relative to active window)" => "\t\t\t{AYSET:n} 设置指针 Y 坐标至 <n> (相对于活动窗口)"
# --

# -- Added in 2.15 Beta 2 - split up in 2.20 Beta 9 --
"Application tags:\t\t{RUN:<application>} {RUN:<full path to exe>}\r\n\t\t\tRun the specified application. If the application is not in the system PATH\r\n\t\t\tplease specify the full path to the executable (including .EXE)" => "程序标记:\t\t{RUN:<application>} {RUN:<full path to exe>}\r\n\t\t\t运行指定程序。如果程序不在系统 PATH 环境变量指定的路径内，请指定目标程序的完整路径 (包括扩展名 .EXE) \r\n\t\t\tplease specify the full path to the executable (including .EXE)"

# -- Added in 2.20 Beta 9 --
"Application tags:\t\t{RUN:<application>} Run the specified application." => "程序标记:\t\t{RUN:<application>} 运行指定程序。"
"\t\t\t{RUNHID:<application>} Run the specified application (hidden)." => "\t\t\t{RUNHID:<application>} 运行指定程序 (隐藏窗口)。" #-- Modified in 2.20 Beta 11
"\t\t\t{RUNMAX:<application>} Run the specified application (maximized)." => "\t\t\t{RUNMAX:<application>} 运行指定程序 (最大化窗口)。" #-- Modified in 2.20 Beta 11
"\t\t\t{RUNMIN:<application>} Run the specified application (minimized)." => "\t\t\t{RUNMIN:<application>} 运行指定程序 (最小化窗口)。" #-- Modified in 2.20 Beta 11
"\t\t\t{RUNINA:<application>} Run the specified application but do not activate the window." => "\t\t\t{RUNINA:<application>} 运行指定程序 (不激活窗口)。" #-- Modified in 2.20 Beta 11
"\t\t\t{RUNADM:<application>} Run the specified application as administrator." => "\t\t\t{RUNADM:<application>} 运行指定程序 (管理员模式)。" #-- Added in 2.20 Beta 11
"\t\t\t{KILL:<executable>} Kill/Terminate processes belonging to executable." => "\t\t\t{KILL:<executable>} 结束指定程序的所有进程。"
"\t\t\tNOTE: For run commands, please specify the full path to the executable (including .EXE)" => "\t\t\t注意: 对于运行命令，请指定目标程序的完整路径 (包括扩展名 .EXE)"
# --

# -- Added in 2.15 Beta 7 --
"Cursor Position: X,Y (AX, AY)" => "指针坐标: X,Y (AX, AY)"

# -- Added in 2.16 Beta 17
"Action tags:" => "动作标记:"
"\t\t{ACTIVATE} Activate the window under the cursor." => "\t\t{ACTIVATE} 激活指针下的窗口。"

# -- Added in 2.18 beta 8 --
"Layer modifier tags:" => "方案辅助按键标记:"
"\t{LAYER:x} Switch to layer <x>" => "\t{LAYER:x} 切换至方案 <x>"
"\t\t\t{LAYER:next} Switch to next layer" => "\t\t\t{LAYER:next} 切换至下一方案"
"\t\t\t{LAYER:back} Switch to preceding layer" => "\t\t\t{LAYER:back} 切换至前一方案"
"\t\t\t{LAYER:last} Switch to the last active layer" => "\t\t\t{LAYER:last} 撤销切换方案"
"On Button Pressed/Released/Repeated tags:" => "按键按下/释放/重复时触发标记:"
"\t\t\t{OD} Only send when the button is pressed" => "\t\t\t{OD} 仅在按键按下时发送"
"\t\t\t{OU} Only send when the button is released" => "\t\t\t{OU} 仅在按键释放时发送"
"\t\t\t{OR} Only send when repeating" => "\t\t\t{OR} 仅在按键重复时发送"
# --

# -- Added in 2.17 Beta 1
"\t\t\t{ACTIVATEPARENT} Activate the parent of the window under the cursor." => "\t\t\t{ACTIVATEPARENT} 激活当前指针下窗口的父级窗口。"
"\t\t\t{ACTIVATETOP} Activate the top level (root) owner of the window under the cursor." => "\t\t\t{ACTIVATETOP} 激活当前指针下窗口的根窗口 (顶级父窗口)。"
# --

# -- Updated in 2.17 Beta 10

# These functions can send any Windows Messages https://msdn.microsoft.com/en-us/library/windows/desktop/ff381405(v=vs.85).aspx
"Windows Message tags:" => "Windows 消息标记:"
"\t{POSTWM:<M>,<L>,<W>} Post a message to the window under the cursor." => "\t{POSTWM:<M>,<L>,<W>} 向当前指针下窗口发送消息 (PostMessage 方式，发出消息后不等待回应)。"
"\t\t\t{SENDWM:<M>,<L>,<W>} Send a message to the window under the cursor." => "\t\t\t{SENDWM:<M>,<L>,<W>} 向当前指针下窗口发送消息 (SendMessage 方式，发出消息后等待回应)。"
"\t\t\tWHERE:\t<M> is the message, <L> is the LPARAM value and <W> is the WPARAM value." => "\t\t\t其中:\t<M> 为消息，<L> 为 LPARAM 参数值，<W> 为 WPARAM 参数值。"
"\t\t\tNOTE:\t<M>, <L> & <W> can be specified in decimal (eg. 16) or hex (eg. 0x10)." => "\t\t\t注意:\t<M>、<L> 和 <W> 可以为十进制 (如 16) 或十六进制 (如 0x10)。"

# -- Added in 2.19 Beta 4
"Media key tags:\t\t{MEDIAPLAY}, {MEDIASTOP}, {MEDIANEXT}, {MEDIAPREV}" => "多媒体键标记:\t\t{MEDIAPLAY}, {MEDIASTOP}, {MEDIANEXT}, {MEDIAPREV}"
"\t\t\t{CURSORBUSY} Switch the mouse pointer to the busy cursor." => "\t\t\t{CURSORBUSY} 将鼠标指针切换为正忙指针。"
"\t\t\t{CURSORDEFAULT} Switch the mouse pointer to the default cursor." => "\t\t\t{CURSORDEFAULT} 将鼠标指针切换为默认指针。"
"\t\t\t{INVERTXY} Invert X and Y Axis." => "\t\t\t{INVERTXY} 反转 X 与 Y 轴。"
"\t\t\t{INVERTX} Invert X Axis." => "\t\t\t{INVERTX} 反转 X 轴。"
"\t\t\t{INVERTY} Invert Y Axis." => "\t\t\t{INVERTY} 反转 Y 轴。"
"\t\t\t{LOCKXY} Lock both X and Y Axis." => "\t\t\t{LOCKXY} 锁定 X 与 Y 轴。"
"\t\t\t{LOCKX} Lock X Axis." => "\t\t\t{LOCKX} 锁定 X 轴。"
"\t\t\t{LOCKY} Lock Y Axis." => "\t\t\t{LOCKY} 锁定 Y 轴。"
"\t\t\t{LOCKC} Cycle Lock X->Y->Unlock Axis." => "\t\t\t{LOCKC} Cycle Lock X->Y->Unlock Axis." #-- Added in 2.20 Beta 4
"\t\t\t{UNLOCKXY} Unlock both X and Y Axis." => "\t\t\t{UNLOCKXY} 解锁 X 与 Y 轴。"
"\t\t\t{UNLOCKX} Unlock X Axis." => "\t\t\t{UNLOCKX} 解锁 X 轴。"
"\t\t\t{UNLOCKY} Unlock Y Axis." => "\t\t\t{UNLOCKY} 解锁 Y 轴。"

#Run Application dialog
"Type the name of a program, folder, document or internet resource, and X-Mouse Button Control will open it for you when the button is pressed." => "输入一个程序、文件夹、文档或者网络资源的名称，X-Mouse Button Control 将会在该按键被按下时为您打开它。" #-- Updated in 2.19 Beta 1

#Open Explorer at specified folder dialog
"Please select a folder to open" => "请选择要打开的文件夹"

#Section: Change Movement to Scroll Configuration -- Added in 2.15 Beta 1
"Movement to Scroll Configuration" => "更改移动为滚动的相关配置"
"Sensitivity" => "灵敏度"
"V&ertical" => "纵向[&E]" #-- Added in 2.19 Beta 11
"H&orizontal" => "横向[&O]" #-- Added in 2.19 Beta 11
"Invert &Vertical Axis" => "反转纵轴[&V]"
"Invert &Horizontal Axis" => "反转横轴[&H]"
"&Sticky (until next click)" => "粘滞 (直到下一次点击) [&S]"
"&Default Action (no movement)" => "默认动作 (无移动) [&D]" #-- Added in 2.17 Beta 1

#Added in 2.17 Beta 6
"Block all other buttons when sticky" => "粘滞时阻止其他所有按键"
"Lock Scroll Axis/Direction" => "锁定滚动轴和滚动方向"
"Don't lock (scroll in any direction)" => "不锁定 (向任意方向滚动)"
"Lock to axis determined by cursor movement" => "根据指针移动确定锁定的滚动轴"
"Lock to Y axis (scroll vertically)" => "锁定 Y 轴 (纵向滚动)"
"Lock to X axis (scroll horizontally)" => "锁定 X 轴 (横向滚动)"
#

#Added in 2.17 Beta  16
"Movement To Scroll Default Action" => "更改移动为滚动的默认动作"

#Section: Scrolling & navigation tab (or Scrolling ad Options tabs post 2.15 Beta 5)
"&Invert mouse wheel scrolling" => "反转鼠标滚轮垂直滚动方向[&I]"
"I&nvert mouse horizontal (tilt) scrolling" => "反转鼠标滚轮水平 (倾斜) 滚动方向[&N]"
"Wheel scrolls i&n pages instead of lines" => "鼠标滚轮按页而非按行滚动[&N]"
"Lines to scroll using the scroll wheel:" => "鼠标滚轮每滚动一格将会滚动的行数" #-- Removed in 2.7 Beta 4. Left for backward compatibility --
"Lines to scroll using the scroll wheel" => "行滚动，每当鼠标滚轮滚动一格" #-- Added/Updated in 2.7 Beta 4 --
"Enable a&xis locking modifier keys" => "启用轴锁定辅助按键组合[&X]"
"Advanced Window Scrolling" => "高级窗口滚动"
"&Scroll Method" => "滚动方式[&S]"
"&Vertical Lines" => "垂直方向行数[&V]"
"&Horizontal characters" => "水平方向字符数[&H]"
"Method 1 (SCROLL Msg)" => "方式 1 (SCROLL Msg)"
"Method 2 (ScrollInfo)" => "方式 2 (ScrollInfo)"
"Method 3 (Left/Right Keys)" => "方式 3 (左/右方向键)"
"Method 4 (Wheel Msg)" => "方式 4 (滚轮消息)"
"Method 5 (WPF Scroll Msg)" => "方式 5 (WPF滚动消息)"
"None (Disable Scroll)" => "无 (禁用滚动)"

# -- Added in 2.7 Beta 7 --
"&Disable Scroll Window Under Cursor" => "禁用直接滚动指针下的窗口 (无论是否激活) [&D]"

# -- Added in 2.8 Beta 6 --
"Switch primary and secondary mouse buttons" => "交换鼠标第一第二按键 (左右键)"
"Don't swap buttons" => "不交换鼠标按键"
"Swap buttons" => "交换鼠标按键"
# --

# -- Added in 2.9 Beta 3 --
"Ignore &repeated remapped vertical scroll" => "忽略重复的重映射垂直滚动[&R]"
"Ignore repeated remapped hori&zontal scroll" => "忽略重复的重映射水平滚动[&Z]"
"for" => "即间隔小于"
"milliseconds" => "毫秒"
# --

# -- Added in 2.13 Beta 9 --
"&Force Scroll Pages/Lines (If application does not respond to setting)" => "强制滚动页/行 (如果应用不响应设置)[&F]" #This option forces the scroll lins/button swap setting to be pushed to ALL open windows.

# -- Added in 2.15 Beta 1 --
"&Clip (lock) mouse cursor to active window" => "将鼠标指针限制在活动窗口内[&C]"

# -- Added in 2.15 Beta 5 --
"&Override Mouse Speed" => "覆盖鼠标速度[&O]"

# -- Added in 2.17 Beta 3 --
"Active window on hover" => "悬停激活窗口"
"Disable &profile switching on mouse move for this profile" => "对此配置文件，禁止在鼠标移动时切换配置文件[&P]"

# -- Added in 2.19 Beta 1 --
"Disable &layer modifier keys for this profile" => "对此配置文件，禁止各方案的辅助按键[&L]"

# -- Added in 2.19 Beta 8
"Change mouse c&ursor when profile is active" => "此配置文件激活时改变鼠标指针[&U]"

# -- Added in 2.20 Beta 9
"Run command when profile is &activated" => "此配置文件激活时运行命令[&A]"

# -- Added in 2.19 Beta 9 -- Coloured cursor options....
"Red" => "红"
"Green" => "绿"
"Blue" => "蓝"
"Orange" => "橙"
"Turquoise" => "青"
